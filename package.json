{
  "name": "kontour-console",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "bin": {
    "kontour": "bin/kontour.js",
    "kontour-console-inspect": "bin/kontour-console-inspect.js"
  },
  "scripts": {
    "build": "npm run typecheck",
    "inspect:fixtures": "node bin/kontour-console-inspect.js",
    "prototype:handoff": "node scripts/serve-prototype.cjs docs/prototypes/handoff-replay",
    "serve": "node bin/kontour.js serve",
    "test": "npm run typecheck && node scripts/check-content-boundary.cjs && node --test test/*.js && node --import tsx --test test/*.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check:content-boundary": "node scripts/check-content-boundary.cjs",
    "setup:repo-hooks": "node scripts/setup-repo-hooks.cjs",
    "validate:repo-hooks": "node scripts/validate-repo-hooks.cjs"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
