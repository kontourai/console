# Kontour hosted Console example.
# Non-secret values only. Copy into deployment config and inject secrets from
# the platform secret manager.

CONSOLE_RUNTIME_MODE=hosted
CONSOLE_HOST=0.0.0.0
CONSOLE_PORT=3000
CONSOLE_PUBLIC_ORIGIN=https://console.kontourai.io
CONSOLE_ALLOWED_ORIGINS=https://console.kontourai.io

# Hosted storage selection. The SQL client dependency and wiring are deployment
# responsibilities until the base package declares and verifies them.
CONSOLE_TELEMETRY_STORAGE=postgres
CONSOLE_DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Tenant bootstrap. Replace example ids with deployment-approved tenant ids.
CONSOLE_TENANT_ID=kontour-default

# Trusted producer tokens must be injected from secrets, not committed here.
CONSOLE_AUTH_TOKEN=replace-with-secret-manager-reference
# For multiple producers/tenants, prefer a secret-manager backed JSON array:
# CONSOLE_AUTH_TOKENS_JSON=[{"token":"...","tenantId":"kontour-default","label":"flow-agents"}]

# Optional descriptor override. If unset, Console uses its documented descriptor
# search paths. Use mounted descriptor files in hosted mode.
CONSOLE_TELEMETRY_DESCRIPTOR_PATHS=../flow-agents/console.telemetry.json
