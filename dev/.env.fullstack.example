# Local full-stack console env (hosted mode) — source this before `npm run serve`.
# Backing services come from docker-compose.dev.yml (Postgres + mock OIDC).
# See docs/deployment/local-fullstack.md. NONE of these are real secrets.

# --- runtime / storage ---
export CONSOLE_RUNTIME_MODE=hosted
export CONSOLE_HOST=127.0.0.1
export CONSOLE_PORT=3000
export CONSOLE_PUBLIC_ORIGIN=http://localhost:3000
export CONSOLE_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5175,http://localhost:5175
export CONSOLE_TELEMETRY_STORAGE=postgres
export CONSOLE_DATABASE_URL=postgres://console:console@localhost:5432/console
export CONSOLE_TELEMETRY_DATABASE_URL=postgres://console:console@localhost:5432/console

# --- tenant ---
export CONSOLE_TENANT_ID=kontour
export CONSOLE_TENANT_ALLOWLIST=kontour
# A dev bearer token (for flow-agents emission / curl), tenant-bound.
export CONSOLE_AUTH_TOKENS_JSON='[{"token":"dev-local-token","tenantId":"kontour"}]'

# --- session signing (#104) ---
export CONSOLE_SESSION_SECRET=dev-local-session-secret-not-for-production-0001

# --- OAuth Resource Server (validates access-token JWTs) ---
# client_id == audience == this URI: the RFC 8707 `resource` param must be an absolute
# URI, and making client_id == audience keeps every token's aud one consistent value.
export CONSOLE_OAUTH_ISSUER=http://localhost:8080/default
export CONSOLE_OAUTH_AUDIENCE=http://localhost:3000
export CONSOLE_OAUTH_JWKS_URI=http://localhost:8080/default/jwks
export CONSOLE_OAUTH_TENANT_CLAIM=org_id

# --- OIDC Authorization-Code + PKCE login ---
export CONSOLE_OAUTH_CLIENT_ID=http://localhost:3000
export CONSOLE_OAUTH_CLIENT_SECRET=dev-local-client-secret
export CONSOLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback
export CONSOLE_OAUTH_AUTHORIZATION_ENDPOINT=http://localhost:8080/default/authorize
export CONSOLE_OAUTH_TOKEN_ENDPOINT=http://localhost:8080/default/token
export CONSOLE_OAUTH_LOGIN_SCOPES="openid profile email"
export CONSOLE_OAUTH_STATE_SECRET=dev-local-state-secret-not-for-production-0001
