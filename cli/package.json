{
  "name": "@kontourai/cli",
  "version": "0.4.0",
  "description": "Offline-first suite router for Kontour products.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kontourai/console.git",
    "directory": "cli"
  },
  "type": "commonjs",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "kontour": "dist/bin/kontour.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schemas/router-output.schema.json": {
      "default": "./schemas/router-output.schema.json"
    },
    "./schemas/init-plan.schema.json": {
      "default": "./schemas/init-plan.schema.json"
    }
  },
  "files": [
    "dist",
    "descriptors",
    "schemas"
  ],
  "scripts": {
    "test": "node --import tsx --test test/*.test.ts",
    "check:import-boundary": "npm run build && node --import tsx scripts/check-import-boundary.ts && node --import tsx scripts/check-import-boundary.ts --compiled && node --import tsx scripts/check-import-boundary.ts --negative",
    "test:tarball": "node --import tsx scripts/test-tarball.ts",
    "test:registry-regression": "node --import tsx scripts/test-public-registry-regression.ts",
    "test:init-e2e": "npm run build && node --import tsx scripts/test-init-tarball.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@kontourai/console-core": "0.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "ajv": "^8.20.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
