{
  "schemaVersion": "1.0.0",
  "protocolVersion": "1.0.0",
  "product": { "id": "console", "displayName": "Kontour Console", "packageName": "@kontourai/console" },
  "executables": [
    { "id": "kontour-cli", "packageBin": "kontour" },
    { "id": "console-inspect-cli", "packageBin": "console-inspect" }
  ],
  "commands": [
    { "path": ["inspect"], "summary": "Inspect local Console events and projections.", "executableId": "console-inspect-cli", "argv": [], "sideEffect": "read-local", "authority": { "kind": "product", "productId": "console", "confirmation": "never" } },
    { "path": ["serve"], "summary": "Serve the local Console management plane.", "executableId": "kontour-cli", "argv": ["serve"], "sideEffect": "read-local", "authority": { "kind": "product", "productId": "console", "confirmation": "user-request" } }
  ],
  "artifacts": [{ "id": "console-control-plane-records", "direction": "input-output", "mediaType": "application/vnd.kontour.console-record+json", "description": "Local event streams and current projection snapshots." }],
  "projections": [{ "id": "console-operating-state", "schemaRef": "@kontourai/console/schemas/projection.schema.json", "description": "Read-only cross-product operating-state projection." }]
}
