{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "paths": {
      "@kontourai/console-core": ["../console-core/src/index.ts"]
    }
  },
  "include": [
    "bin/**/*.ts",
    "src/**/*.ts",
    "test/**/*.ts"
  ]
}
