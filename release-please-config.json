{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "include-component-in-tag": false,
  "plugins": ["node-workspace"],
  "packages": {
    ".": {
      "exclude-paths": [
        "cli",
        "console-core",
        "console-server"
      ]
    },
    "cli": {
      "component": "cli",
      "package-name": "@kontourai/cli",
      "include-component-in-tag": true,
      "extra-files": [
        {
          "type": "json",
          "path": "/package-lock.json",
          "jsonpath": "$.packages.cli.version"
        }
      ]
    },
    "console-core": {
      "component": "console-core",
      "package-name": "@kontourai/console-core",
      "include-component-in-tag": true,
      "extra-files": [
        {
          "type": "json",
          "path": "/package-lock.json",
          "jsonpath": "$.packages.console-core.version"
        },
        {
          "type": "json",
          "path": "/package-lock.json",
          "jsonpath": "$.packages.cli.dependencies['@kontourai/console-core']"
        },
        {
          "type": "json",
          "path": "/console-server/package.json",
          "jsonpath": "$.dependencies['@kontourai/console-core']"
        },
        {
          "type": "json",
          "path": "/package-lock.json",
          "jsonpath": "$.packages.console-server.dependencies['@kontourai/console-core']"
        },
        {
          "type": "json",
          "path": "/package-lock.json",
          "jsonpath": "$.packages[''].dependencies['@kontourai/console-core']"
        }
      ]
    },
    "console-server": {
      "component": "console-server",
      "package-name": "@kontourai/console-server",
      "include-component-in-tag": true,
      "extra-files": [
        {
          "type": "json",
          "path": "/package-lock.json",
          "jsonpath": "$.packages.console-server.version"
        }
      ]
    }
  }
}
