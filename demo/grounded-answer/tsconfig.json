{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@kontourai/survey": ["../../node_modules/@kontourai/survey/dist/src/index.d.ts"],
      "@kontourai/surface": ["../../node_modules/@kontourai/surface/dist/src/index.d.ts"]
    }
  },
  "include": ["./**/*.ts"]
}
